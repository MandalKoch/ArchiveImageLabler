@if (Archives.Count == 0 && Images.Count == 0)
{
    <div class="empty-state inline">
        <h2>No media</h2>
    </div>
}
else
{
    <div class="image-grid">
        @foreach (var archive in Archives)
        {
            <article @key="archive.Id"
                     class="@ArchiveCardClass(archive)"
                     draggable="@IsDraggableArchive(archive)"
                     @ondragstart="() => StartArchiveDrag(archive.Id)"
                     @ondragend="ClearArchiveDrag"
                     @ondragover:preventDefault="true"
                     @ondrop="() => DropArchiveAsync(archive.Id)">
                @SelectionControl(archive)
                <button type="button" class="image-card-open" @onclick="args => OpenOrSelectArchiveAsync(archive, args)">
                    <span class="archive-card-preview">
                        <Preview AssetId="archive.PreviewImageId" AssetKind="archive.PreviewKind" />
                    </span>
                    <span class="asset-type-badge archive">@ArchiveTypeLabel(archive)</span>
                    <span class="image-name">@archive.DisplayName</span>
                    <span class="stars">@ArchiveStatus(archive)</span>
                </button>
                @RatingControls(archive)
                <div class="archive-card-actions">
                    <button type="button" class="quick-rating-clear" @onclick="() => OnChooseArchivePreview.InvokeAsync(archive)">Preview</button>
                    @if (archive.Kind == AssetKinds.Zip)
                    {
                        <button type="button" class="quick-rating-clear" @onclick="() => OnToggleArchiveIgnored.InvokeAsync(archive)">
                            @(archive.IsIgnored ? "Unignore" : "Ignore")
                        </button>
                    }
                </div>
            </article>
        }

        @foreach (var item in Images)
        {
            <article @key="item.Id" class="@ImageCardClass(item)">
                @SelectionControl(item)
                <button type="button" class="image-card-open" @onclick="args => OpenOrSelectImageAsync(item, args)">
                    @MediaThumb(item)
                    <span class="@AssetTypeBadgeClass(item)">@AssetTypeLabel(item)</span>
                    <span class="image-name">@item.DisplayName</span>
                    <span class="stars">@StatusBadge(item)</span>
                </button>
                @RatingControls(item)
            </article>
        }
    </div>
}

@code {
    [Parameter] public List<AssetCard> Archives { get; set; } = [];

    [Parameter, EditorRequired] public List<AssetCard> Images { get; set; } = [];

    [Parameter, EditorRequired] public EventCallback<AssetCard> OnOpen { get; set; }

    [Parameter] public EventCallback<AssetCard> OnOpenArchive { get; set; }

    [Parameter] public EventCallback<AssetRatingChange> OnRate { get; set; }

    [Parameter] public EventCallback<AssetCard> OnToggleArchiveIgnored { get; set; }

    [Parameter] public EventCallback<AssetCard> OnChooseArchivePreview { get; set; }

    [Parameter] public EventCallback<IReadOnlyList<long>> OnArchiveReorder { get; set; }

    [Parameter] public IReadOnlySet<long> SelectedAssetIds { get; set; } = new HashSet<long>();

    [Parameter] public EventCallback<AssetSelectionChange> OnToggleSelection { get; set; }

    [Parameter] public Func<long, string>? MediaUrlForAsset { get; set; }

    private long? _draggingArchiveId;

    private string MediaUrl(long id) => MediaUrlForAsset?.Invoke(id) ?? $"/api/assets/{id}/content";

    private static string Stars(int? rating) => rating is null ? "Unrated" : new string('*', rating.Value);

    private static string StatusBadge(AssetCard asset) => asset.IsIgnored ? "Ignored" : Stars(asset.Rating);

    private static string ArchiveStatus(AssetCard archive)
    {
        if (archive.IsIgnored)
        {
            return "Ignored";
        }

        if (archive.SourceType == AssetSourceTypes.ArchiveGroup)
        {
            var archiveText = archive.ChildCount == 1 ? "1 archive" : $"{archive.ChildCount} archives";
            return $"{archiveText}, {archive.ImageCount} media files";
        }

        return $"{archive.ImageCount} media files";
    }

    private static string ArchiveTypeLabel(AssetCard archive)
    {
        return archive.SourceType == AssetSourceTypes.ArchiveGroup ? "Group" : "Archive";
    }

    private string ArchiveCardClass(AssetCard archive)
    {
        var classes = new List<string> { "image-card", "archive-card" };
        if (archive.SourceType == AssetSourceTypes.ArchiveGroup)
        {
            classes.Add("archive-group-card");
        }

        if (archive.IsIgnored)
        {
            classes.Add("ignored");
        }

        if (SelectedAssetIds.Contains(archive.Id))
        {
            classes.Add("selected");
        }

        if (_draggingArchiveId == archive.Id)
        {
            classes.Add("dragging");
        }

        return string.Join(" ", classes);
    }

    private string ImageCardClass(AssetCard asset)
    {
        var classes = new List<string> { "image-card" };
        if (SelectedAssetIds.Contains(asset.Id))
        {
            classes.Add("selected");
        }

        return string.Join(" ", classes);
    }

    private static bool IsDraggableArchive(AssetCard archive)
    {
        return archive.Kind == AssetKinds.Zip;
    }

    private void StartArchiveDrag(long archiveId)
    {
        if (Archives.FirstOrDefault(archive => archive.Id == archiveId) is { Kind: AssetKinds.Zip })
        {
            _draggingArchiveId = archiveId;
        }
    }

    private void ClearArchiveDrag()
    {
        _draggingArchiveId = null;
    }

    private async Task DropArchiveAsync(long targetArchiveId)
    {
        var targetArchive = Archives.FirstOrDefault(archive => archive.Id == targetArchiveId);
        if (targetArchive?.Kind != AssetKinds.Zip ||
            _draggingArchiveId is not { } sourceArchiveId ||
            sourceArchiveId == targetArchiveId)
        {
            ClearArchiveDrag();
            return;
        }

        var orderedIds = Archives
            .Where(archive => archive.Kind == AssetKinds.Zip)
            .Select(archive => archive.Id)
            .ToList();
        var sourceIndex = orderedIds.IndexOf(sourceArchiveId);
        var targetIndex = orderedIds.IndexOf(targetArchiveId);
        if (sourceIndex < 0 || targetIndex < 0)
        {
            ClearArchiveDrag();
            return;
        }

        orderedIds.RemoveAt(sourceIndex);
        if (sourceIndex < targetIndex)
        {
            targetIndex--;
        }

        orderedIds.Insert(targetIndex, sourceArchiveId);
        ClearArchiveDrag();
        await OnArchiveReorder.InvokeAsync(orderedIds);
    }

    private async Task OpenOrSelectArchiveAsync(AssetCard archive, MouseEventArgs args)
    {
        if (args.CtrlKey || args.MetaKey || args.ShiftKey)
        {
            await OnToggleSelection.InvokeAsync(new AssetSelectionChange(archive.Id, args.ShiftKey, args.CtrlKey || args.MetaKey, Toggle: false));
            return;
        }

        await OnOpenArchive.InvokeAsync(archive);
    }

    private async Task OpenOrSelectImageAsync(AssetCard asset, MouseEventArgs args)
    {
        if (args.CtrlKey || args.MetaKey || args.ShiftKey)
        {
            await OnToggleSelection.InvokeAsync(new AssetSelectionChange(asset.Id, args.ShiftKey, args.CtrlKey || args.MetaKey, Toggle: false));
            return;
        }

        await OnOpen.InvokeAsync(asset);
    }

    private RenderFragment SelectionControl(AssetCard asset) => builder =>
    {
        var isSelected = SelectedAssetIds.Contains(asset.Id);
        builder.OpenElement(0, "label");
        builder.AddAttribute(1, "class", "image-select");
        builder.AddAttribute(2, "title", isSelected ? "Remove from selection" : "Add to selection");
        builder.OpenElement(3, "input");
        builder.AddAttribute(4, "type", "checkbox");
        builder.AddAttribute(5, "checked", isSelected);
        builder.AddAttribute(6, "onchange", EventCallback.Factory.Create(this, () => OnToggleSelection.InvokeAsync(new AssetSelectionChange(asset.Id, ShiftKey: false, AdditiveKey: true, Toggle: true))));
        builder.CloseElement();
        builder.OpenElement(7, "span");
        builder.CloseElement();
        builder.CloseElement();
    };

    private static string AssetTypeLabel(AssetCard asset)
    {
        return asset.Kind switch
        {
            AssetKinds.Audio => "Audio",
            AssetKinds.Video => "Video",
            _ => "Image"
        };
    }

    private static string AssetTypeBadgeClass(AssetCard asset)
    {
        return asset.Kind switch
        {
            AssetKinds.Audio => "asset-type-badge audio",
            AssetKinds.Video => "asset-type-badge video",
            _ => "asset-type-badge image"
        };
    }

    private static string RatingButtonClass(AssetCard asset, int rating)
    {
        return asset.Rating >= rating ? "quick-rating-star active" : "quick-rating-star";
    }

    private RenderFragment RatingControls(AssetCard asset) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "overview-rating");
        builder.AddAttribute(2, "aria-label", $"Rate {asset.DisplayName}");

        for (var rating = 1; rating <= 5; rating++)
        {
            var currentRating = rating;
            builder.OpenElement(3 + rating, "button");
            builder.AddAttribute(8 + rating, "type", "button");
            builder.AddAttribute(13 + rating, "class", RatingButtonClass(asset, currentRating));
            builder.AddAttribute(18 + rating, "title", $"Rate {currentRating} stars");
            builder.AddAttribute(23 + rating, "onclick", EventCallback.Factory.Create(this, () => OnRate.InvokeAsync(new AssetRatingChange(asset, currentRating))));
            builder.AddMarkupContent(28 + rating, "&#9733;");
            builder.CloseElement();
        }

        builder.OpenElement(34, "button");
        builder.AddAttribute(35, "type", "button");
        builder.AddAttribute(36, "class", "quick-rating-clear");
        builder.AddAttribute(37, "title", "Clear rating");
        builder.AddAttribute(38, "onclick", EventCallback.Factory.Create(this, () => OnRate.InvokeAsync(new AssetRatingChange(asset, null))));
        builder.AddContent(39, "Clear");
        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment MediaThumb(AssetCard asset) => builder =>
    {
        if (asset.IsImage)
        {
            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "src", MediaUrl(asset.Id));
            builder.AddAttribute(2, "alt", asset.DisplayName);
            builder.CloseElement();
            return;
        }

        if (asset.IsVideo)
        {
            builder.OpenElement(3, "video");
            builder.AddAttribute(4, "src", $"{MediaUrl(asset.Id)}#t=0.1");
            builder.AddAttribute(5, "preload", "metadata");
            builder.AddAttribute(6, "muted", true);
            builder.AddAttribute(7, "playsinline", true);
            builder.CloseElement();
            return;
        }

        builder.OpenElement(8, "span");
        builder.AddAttribute(9, "class", "media-placeholder");
        builder.OpenElement(10, "span");
        builder.AddAttribute(11, "class", "media-kind");
        builder.AddContent(12, "AUD");
        builder.CloseElement();
        builder.CloseElement();
    };
}
