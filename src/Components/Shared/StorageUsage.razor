@inject IOptions<LibraryOptions> Options
@implements IAsyncDisposable

<div class="memory-widget" title="Storage used under @Options.Value.DataPath">
    <span>Storage</span>
    <strong>@FormatBytes(_snapshot.DataBytes)</strong>
    <small>Cache @FormatBytes(_snapshot.CacheBytes)</small>
</div>

@code {
    private readonly CancellationTokenSource _refreshCancellation = new();
    private Task? _refreshTask;
    private StorageSnapshot _snapshot = StorageSnapshot.Empty;

    protected override void OnInitialized()
    {
        _refreshTask = RefreshLoopAsync();
    }

    private async Task RefreshLoopAsync()
    {
        try
        {
            _snapshot = await CaptureAsync(_refreshCancellation.Token);
            await InvokeAsync(StateHasChanged);

            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (await timer.WaitForNextTickAsync(_refreshCancellation.Token))
            {
                _snapshot = await CaptureAsync(_refreshCancellation.Token);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private Task<StorageSnapshot> CaptureAsync(CancellationToken cancellationToken)
    {
        var dataPath = Options.Value.DataPath;
        var cachePath = Path.Combine(dataPath, "cache");
        return Task.Run(() => new StorageSnapshot(
            DirectorySize(dataPath, cancellationToken),
            DirectorySize(cachePath, cancellationToken)), cancellationToken);
    }

    private static long DirectorySize(string path, CancellationToken cancellationToken)
    {
        if (!Directory.Exists(path))
        {
            return 0;
        }

        long total = 0;
        var pending = new Stack<string>();
        pending.Push(path);

        while (pending.Count > 0)
        {
            cancellationToken.ThrowIfCancellationRequested();
            var current = pending.Pop();

            try
            {
                foreach (var directory in Directory.EnumerateDirectories(current))
                {
                    pending.Push(directory);
                }

                foreach (var file in Directory.EnumerateFiles(current))
                {
                    cancellationToken.ThrowIfCancellationRequested();
                    try
                    {
                        total += new FileInfo(file).Length;
                    }
                    catch (Exception ex) when (ex is IOException or UnauthorizedAccessException)
                    {
                    }
                }
            }
            catch (Exception ex) when (ex is IOException or UnauthorizedAccessException)
            {
            }
        }

        return total;
    }

    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var unitIndex = 0;
        double display = bytes;

        while (display >= 1024 && unitIndex < units.Length - 1)
        {
            display /= 1024;
            unitIndex++;
        }

        return unitIndex == 0
            ? $"{display:0} {units[unitIndex]}"
            : $"{display:0.0} {units[unitIndex]}";
    }

    public async ValueTask DisposeAsync()
    {
        await _refreshCancellation.CancelAsync();
        if (_refreshTask is not null)
        {
            try
            {
                await _refreshTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _refreshCancellation.Dispose();
    }

    private sealed record StorageSnapshot(long DataBytes, long CacheBytes)
    {
        public static StorageSnapshot Empty { get; } = new(0, 0);
    }
}
