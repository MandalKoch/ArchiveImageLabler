    private void UpdateAssetMetadata(long id, string labelName, string description, string tags, int? rating)
    {
        if (_snapshot is not null)
        {
            _snapshot = _snapshot with
            {
                Containers = _snapshot.Containers.Select(asset => UpdateAssetCardMetadata(asset, id, labelName, description, tags, rating)).ToList(),
                Archives = _snapshot.Archives.Select(asset => UpdateAssetCardMetadata(asset, id, labelName, description, tags, rating)).ToList(),
                Images = _snapshot.Images.Select(asset => UpdateAssetCardMetadata(asset, id, labelName, description, tags, rating)).ToList()
            };
        }

        if (_viewerAsset?.Id == id)
        {
            _viewerAsset = UpdateAssetCardMetadata(_viewerAsset, id, labelName, description, tags, rating);
        }

        if (_editingAsset?.Id == id)
        {
            _editingAsset = UpdateAssetCardMetadata(_editingAsset, id, labelName, description, tags, rating);
        }
    }

    private static AssetCard UpdateAssetCardMetadata(AssetCard asset, long id, string labelName, string description, string tags, int? rating)
    {
        return asset.Id == id
            ? asset with { LabelName = labelName.Trim(), Description = description.Trim(), Tags = string.Join(", ", ParseTags(tags)), Rating = rating is >= 1 and <= 5 ? rating : null }
            : asset;
    }

