    private void UpdateAssetRating(long id, int? rating)
    {
        var normalizedRating = rating is >= 1 and <= 5 ? rating : null;
        if (_snapshot is not null)
        {
            _snapshot = _snapshot with
            {
                Containers = _snapshot.Containers.Select(asset => UpdateAssetCardRating(asset, id, normalizedRating)).ToList(),
                Archives = _snapshot.Archives.Select(asset => UpdateAssetCardRating(asset, id, normalizedRating)).ToList(),
                Images = _snapshot.Images.Select(asset => UpdateAssetCardRating(asset, id, normalizedRating)).ToList()
            };
        }

        if (_viewerAsset?.Id == id)
        {
            _viewerAsset = _viewerAsset with { Rating = normalizedRating };
        }

        if (_editingAsset?.Id == id)
        {
            _editingAsset = _editingAsset with { Rating = normalizedRating };
            _editRating = normalizedRating;
        }
    }

