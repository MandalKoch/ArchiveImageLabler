@page "/"
@rendermode InteractiveServer
@inject LibraryScanner Scanner
@inject LibraryQueries Library
@inject IOptions<LibraryOptions> Options
@inject IJSRuntime JsRuntime
@implements IAsyncDisposable

<PageTitle>FileZipPreview</PageTitle>

<div class="shell">
    <header class="app-header">
        <div>
            <p class="eyebrow">Mounted library</p>
            <h1>FileZipPreview</h1>
            <p class="path">@Options.Value.RootPath</p>
        </div>

        <div class="toolbar">
            <MemoryUsage />
            <button class="@LabelAffeButtonClass" @onclick="ToggleLabelAffeAsync">
                @(_labelAffeMode ? "Exit LabelAffe" : "LabelAffe")
            </button>
            <button class="primary-button" @onclick="ScanAsync" disabled="@_isScanning" title="Refresh folders, keep archive previews, and prune missing entries. Full archive scans happen when opening an archive.">
                @(_isScanning ? _scanStatus : "Scan")
            </button>
            <button class="danger-button" @onclick="RescanAsync" disabled="@_isScanning" title="Delete indexed assets, including tags, ratings, and descriptions, then run a fast scan">
                Rescan
            </button>
            @if (_isScanning)
            {
                <button class="secondary-button" @onclick="CancelRootScan">Cancel</button>
            }
        </div>
    </header>

    <section class="stats-band">
        <div><span>@(_snapshot?.Totals.Images ?? 0)</span><label>Media</label></div>
        <div><span>@(_snapshot?.Totals.Archives ?? 0)</span><label>Archives</label></div>
        <div><span>@(_snapshot?.Totals.Missing ?? 0)</span><label>Missing</label></div>
        <div><span>@(_snapshot?.Totals.Errors ?? 0)</span><label>Errors</label></div>
    </section>

    @if (_lastScan is not null)
    {
        <div class="scan-note">
            Indexed @_lastScan.Images media files and @_lastScan.Containers containers. Removed @_lastScan.Pruned database entries. @_lastScan.Errors scan errors.
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_scanMessage))
    {
        <div class="scan-note">
            @_scanMessage
        </div>
    }

    @if (_isScanning && _folderScanProgress is not null)
    {
        <section class="progress-panel">
            <div>
                <strong>@_folderScanProgress.Phase</strong>
                <span>@_folderScanProgress.CurrentItem</span>
            </div>
            <div class="@ProgressBarClass(_folderScanProgress)"><span style="@ProgressBarStyle(_folderScanProgress)"></span></div>
            <div class="progress-count">@ProgressWorkText(_folderScanProgress)</div>
            <small>@_folderScanProgress.Images media files · @_folderScanProgress.Containers containers · @_folderScanProgress.Errors errors</small>
        </section>
    }

    @if (_isArchiveScanning && _archiveScanProgress is not null)
    {
        <section class="progress-panel archive-progress">
            <div>
                <strong>@_archiveScanProgress.Phase</strong>
                <span>@_archiveScanProgress.CurrentItem</span>
            </div>
            <div class="@ProgressBarClass(_archiveScanProgress)"><span style="@ProgressBarStyle(_archiveScanProgress)"></span></div>
            <div class="progress-count">@ProgressWorkText(_archiveScanProgress)</div>
            <small>@_archiveScanProgress.Images media files found · @_archiveScanProgress.Errors errors</small>
            <button class="secondary-button" @onclick="CancelArchiveScan">Cancel</button>
        </section>
    }

    <section class="filters">
        <input placeholder="Search labels, names, tags, descriptions" @bind="_search" @bind:event="oninput" />
        <select @bind="_ratingFilter">
            <option value="">Any rating</option>
            <option value="5">5 stars only</option>
            <option value="4">4+ stars</option>
            <option value="3">3+ stars</option>
            <option value="2">2+ stars</option>
            <option value="1">1+ star</option>
        </select>
        <label class="check">
            <input type="checkbox" @bind="_unratedOnly" />
            Unrated
        </label>
        <button class="secondary-button" @onclick="LoadAsync">Apply</button>
    </section>

    @if (_snapshot is null)
    {
        <div class="empty-state">
            <h2>No scan loaded</h2>
            <p>@Options.Value.RootPath</p>
        </div>
    }
    else
    {
        @if (_labelAffeMode)
        {
            <section class="labelaffe-workspace">
                <aside class="labelaffe-list">
                    <div class="panel-title">
                        <span>Archives</span>
                        <small>@LabelArchives().Count() items</small>
                    </div>

                    @foreach (var archive in LabelArchives())
                    {
                        <button class="labelaffe-archive @(archive.Id == _labelArchiveId ? "active" : null)" @onclick="() => SelectLabelArchiveAsync(archive)">
                            <Preview AssetId="archive.PreviewImageId" AssetKind="archive.PreviewKind" />
                            <span>
                                <strong>@archive.DisplayName</strong>
                                @if (!string.IsNullOrWhiteSpace(archive.LabelName))
                                {
                                    <small>@archive.Name</small>
                                }
                                <small>@archive.Tags</small>
                            </span>
                        </button>
                    }
                </aside>

                <section class="labelaffe-editor">
                    @if (SelectedLabelArchive is null)
                    {
                        <div class="empty-state inline">
                            <h2>No archive selected</h2>
                        </div>
                    }
                    else
                    {
                        var archive = SelectedLabelArchive!;
                        <div class="panel-heading">
                            <div>
                                <p class="eyebrow">LabelAffe</p>
                                <h2>@archive.DisplayName</h2>
                                <p class="path dark">@archive.RelativePath</p>
                            </div>
                            <Preview AssetId="archive.PreviewImageId" AssetKind="archive.PreviewKind" />
                        </div>

                        <div class="labelaffe-form">
                            <label class="field flush">
                                <span>Archive name</span>
                                <input value="@_labelName" @oninput="HandleLabelNameInput" list="label-name-suggestions" placeholder="@archive.Name" />
                            </label>

                            <div class="suggestion-row">
                                @foreach (var suggestion in NameSuggestions(archive).Take(8))
                                {
                                    <button class="suggestion-chip" @onclick="() => ApplyNameSuggestionAsync(suggestion)">@suggestion</button>
                                }
                            </div>

                            <label class="field flush">
                                <span>Add tags</span>
                                <div class="tag-entry">
                                    <input @bind="_labelTagInput" @bind:event="oninput" @onkeyup="HandleLabelTagKeyUp" list="tag-suggestions" placeholder="type tag and press Enter" />
                                    <button class="secondary-button" @onclick="AddLabelTagFromInputAsync">Add</button>
                                </div>
                            </label>

                            <div class="assigned-tags">
                                <span>Current tags</span>
                                @if (_labelTags.Count == 0)
                                {
                                    <small>No tags assigned</small>
                                }
                                else
                                {
                                    <div class="tag-chip-row">
                                        @foreach (var tag in _labelTags)
                                        {
                                            <button class="tag-chip selected" title="Remove @tag" @onclick="() => RemoveLabelTagAsync(tag)">
                                                <span>@tag</span>
                                                <strong aria-hidden="true">x</strong>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="suggestion-row">
                                @foreach (var suggestion in TagSuggestions(archive).Take(16))
                                {
                                    <button class="suggestion-chip" @onclick="() => AddLabelTagAsync(suggestion)">@suggestion</button>
                                }
                            </div>

                            <label class="field flush">
                                <span>Description</span>
                                <textarea value="@_labelDescription" @oninput="HandleLabelDescriptionInput" rows="5"></textarea>
                            </label>

                            <div class="suggestion-row">
                                @foreach (var suggestion in TextSuggestions(archive).Take(6))
                                {
                                    <button class="suggestion-chip text" @onclick="() => ApplyTextSuggestionAsync(suggestion)">@suggestion</button>
                                }
                            </div>

                            <label class="field flush compact-field">
                                <span>Rating</span>
                                <select value="@RatingInputValue(_labelRating)" @onchange="HandleLabelRatingChanged">
                                    <option value="">Unrated</option>
                                    <option value="5">5 stars</option>
                                    <option value="4">4 stars</option>
                                    <option value="3">3 stars</option>
                                    <option value="2">2 stars</option>
                                    <option value="1">1 star</option>
                                </select>
                            </label>

                            <div class="drawer-actions flush">
                                <button class="primary-button" @onclick="SaveLabelAffeAsync">Save</button>
                                <button class="secondary-button" @onclick="SaveAndNextLabelAffeAsync">Save and next</button>
                            </div>
                        </div>
                    }
                </section>
            </section>

            <datalist id="label-name-suggestions">
                @foreach (var suggestion in _labelSuggestions.Names)
                {
                    <option value="@suggestion"></option>
                }
            </datalist>

            <datalist id="tag-suggestions">
                @foreach (var suggestion in _labelSuggestions.Tags)
                {
                    <option value="@suggestion"></option>
                }
            </datalist>
        }
        else
        {
            <section class="workspace">
            <aside class="source-list">
                <div class="panel-title">
                    <span>Sources</span>
                    <label class="sidebar-toggle">
                        <input type="checkbox" @bind="_showArchivesOnly" />
                        Archives
                    </label>
                </div>

                @foreach (var container in VisibleContainers())
                {
                    var hasChildren = !_showArchivesOnly && HasSourceChildren(container);
                    <div class="source-tree-row" style="@SourceIndent(container, _showArchivesOnly)">
                        <button class="source-toggle @(hasChildren ? null : "hidden")" title="@(IsSourceCollapsed(container.Id) ? "Expand" : "Collapse")" disabled="@(!hasChildren)" @onclick="() => ToggleSourceCollapsed(container.Id)">
                            @(IsSourceCollapsed(container.Id) ? ">" : "v")
                        </button>
                        <button class="source-card @(container.Id == _snapshot.ActiveContainerId ? "active" : null) @(container.IsIgnored ? "ignored" : null)" @onclick="() => SelectContainerAsync(container.Id)">
                            <Preview AssetId="container.PreviewImageId" AssetKind="container.PreviewKind" />
                            <span class="source-copy">
                                <strong>@container.DisplayName</strong>
                                <small>@DisplaySourceType(container)</small>
                                <small>@SourceStatus(container)</small>
                            </span>
                            <span class="stars">@StatusBadge(container)</span>
                        </button>
                    </div>
                }
            </aside>

            <section class="preview-panel">
                <div class="panel-heading">
                    <div>
                        <p class="eyebrow">Preview</p>
                        <h2>@SelectedContainerName</h2>
                    </div>
                    <div class="panel-actions">
                        @if (SelectedContainer is not null)
                        {
                            var selectedContainer = SelectedContainer;
                            <div class="quick-rating" aria-label="Rate @selectedContainer.DisplayName">
                                @foreach (var rating in RatingValues)
                                {
                                    <button type="button" class="@QuickRatingButtonClass(selectedContainer, rating)" title="@($"Rate {rating} stars")" @onclick="() => RateAssetAsync(selectedContainer, rating)">&#9733;</button>
                                }
                                <button type="button" class="quick-rating-clear" title="Clear rating" @onclick="() => ClearAssetRatingAsync(selectedContainer)">Clear</button>
                            </div>
                            <button class="icon-button" title="Edit metadata" @onclick="() => EditAsset(selectedContainer)">Edit</button>
                            @if (selectedContainer.Kind == AssetKinds.Zip)
                            {
                                <button class="secondary-button" @onclick="() => ToggleIgnoredAsync(selectedContainer)">
                                    @(selectedContainer.IsIgnored ? "Unignore" : "Ignore")
                                </button>
                            }
                            <a class="secondary-button" href="@SourcePageUrl(selectedContainer.Id)" target="_blank" rel="noopener">Open page</a>
                        }
                    </div>
                </div>

                <ImageGrid Archives="_snapshot.Archives" Images="_snapshot.Images" OnOpen="OpenViewer" OnOpenArchive="OpenArchiveFromPreviewAsync" />
            </section>
            </section>
        }
    }
</div>

@if (_editingAsset is not null)
{
    <div class="drawer">
        <div class="drawer-panel">
            <div class="panel-heading compact">
                <div>
                    <p class="eyebrow">@_editingAsset.Kind</p>
                    <h2>@_editingAsset.DisplayName</h2>
                </div>
                <button class="icon-button" title="Close" @onclick="CloseEditor">x</button>
            </div>

            @if (_editingAsset.PreviewImageId is not null)
            {
                @if (_editingAsset.PreviewKind == AssetKinds.Video)
                {
                    <video class="viewer-image" src="@ImageUrl(_editingAsset.PreviewImageId.Value)#t=0.1" controls preload="metadata" muted loop></video>
                }
                else
                {
                    <img class="viewer-image" src="@ImageUrl(_editingAsset.PreviewImageId.Value)" alt="@_editingAsset.DisplayName" />
                }
            }

            <label class="field">
                <span>Label name</span>
                <input @bind="_editLabelName" list="label-name-suggestions" placeholder="@_editingAsset.Name" />
            </label>

            <label class="field">
                <span>Rating</span>
                <select @bind="_editRating">
                    <option value="">Unrated</option>
                    <option value="5">5 stars</option>
                    <option value="4">4 stars</option>
                    <option value="3">3 stars</option>
                    <option value="2">2 stars</option>
                    <option value="1">1 star</option>
                </select>
            </label>

            <label class="field">
                <span>Tags</span>
                <input @bind="_editTags" placeholder="portrait, reference, favorite" />
            </label>

            <label class="field">
                <span>Description</span>
                <textarea @bind="_editDescription" rows="5"></textarea>
            </label>

            <div class="drawer-actions">
                <button class="primary-button" @onclick="SaveMetadataAsync">Save</button>
                <button class="secondary-button" @onclick="CloseEditor">Cancel</button>
            </div>
        </div>
    </div>
}

@if (_viewerAsset is not null)
{
    <div class="viewer">
        <button class="viewer-backdrop" title="Close viewer" @onclick="CloseViewer"></button>
        <div class="viewer-panel">
            <header class="viewer-topbar">
                <div>
                    <p class="eyebrow">@DisplaySourceType(_viewerAsset)</p>
                    <h2>@_viewerAsset.DisplayName</h2>
                </div>
                <div class="viewer-controls">
                    <button class="secondary-button" @onclick="PreviousImage">Previous</button>
                    <button class="secondary-button" @onclick="NextImage">Next</button>
                    <div class="quick-rating inverse" aria-label="Rate @_viewerAsset.DisplayName">
                        @foreach (var rating in RatingValues)
                        {
                            <button type="button" class="@QuickRatingButtonClass(_viewerAsset, rating)" title="@($"Rate {rating} stars")" @onclick="() => RateAssetAsync(_viewerAsset, rating)">&#9733;</button>
                        }
                        <button type="button" class="quick-rating-clear" title="Clear rating" @onclick="() => ClearAssetRatingAsync(_viewerAsset)">Clear</button>
                    </div>
                    <button class="primary-button" @onclick="() => EditAsset(_viewerAsset)">Edit</button>
                    <button class="icon-button" title="Close" @onclick="CloseViewer">x</button>
                </div>
            </header>
            <div class="viewer-stage">
                @ViewerMedia(_viewerAsset)
            </div>
            <footer class="viewer-filmstrip">
                <div class="viewer-meta-line">
                    <span class="muted">@_viewerAsset.RelativePath</span>
                    <span class="stars">@StatusBadge(_viewerAsset)</span>
                    @if (!string.IsNullOrWhiteSpace(_viewerAsset.Tags))
                    {
                        <span class="tags">@_viewerAsset.Tags</span>
                    }
                </div>
                <div class="filmstrip-row">
                    @foreach (var image in CurrentImages())
                    {
                        <button @key="image.Id" class="filmstrip-item @(image.Id == _viewerAsset.Id ? "active" : null)" title="@image.DisplayName" @onclick="() => ShowViewerImageAsync(image)">
                            @FilmstripMedia(image)
                        </button>
                    }
                </div>
            </footer>
        </div>
    </div>
}

@code {
    private static readonly int[] RatingValues = [1, 2, 3, 4, 5];

    private LibrarySnapshot? _snapshot;
    private ScanSummary? _lastScan;
    private string? _scanMessage;
    private string _search = string.Empty;
    private string _ratingFilter = string.Empty;
    private bool _unratedOnly;
    private bool _isScanning;
    private string _scanStatus = "Scanning";
    private bool _isArchiveScanning;
    private bool _isRefreshingArchivePreview;
    private ScanProgress? _folderScanProgress;
    private ScanProgress? _archiveScanProgress;
    private DateTimeOffset _lastArchivePreviewRefresh = DateTimeOffset.MinValue;
    private int _lastArchivePreviewImageCount;
    private AssetCard? _editingAsset;
    private AssetCard? _viewerAsset;
    private string _editLabelName = string.Empty;
    private string _editDescription = string.Empty;
    private string _editTags = string.Empty;
    private int? _editRating;
    private DotNetObjectReference<Home>? _keyboardReference;
    private bool _keyboardConnected;
    private bool _labelKeyboardConnected;
    private CancellationTokenSource? _rootScanCancellation;
    private CancellationTokenSource? _archiveScanCancellation;
    private readonly HashSet<long> _collapsedSourceIds = [];
    private bool _showArchivesOnly;
    private bool _labelAffeMode;
    private long? _labelArchiveId;
    private string _labelName = string.Empty;
    private string _labelDescription = string.Empty;
    private string _labelTagInput = string.Empty;
    private readonly List<string> _labelTags = [];
    private int? _labelRating;
    private LabelSuggestions _labelSuggestions = new([], [], []);
    private CancellationTokenSource? _labelAutosaveCancellation;
    private bool _labelAffeDirty;

    private AssetCard? SelectedContainer => _snapshot?.Containers.SingleOrDefault(container => container.Id == _snapshot.ActiveContainerId);

    private string SelectedContainerName => SelectedContainer?.DisplayName ?? "Select a source";

    private AssetCard? SelectedLabelArchive => LabelArchives().FirstOrDefault(archive => archive.Id == _labelArchiveId) ?? LabelArchives().FirstOrDefault();

    private string LabelAffeButtonClass => _labelAffeMode ? "secondary-button active-mode" : "secondary-button";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ScanAsync()
    {
        await RunRootScanAsync("Scanning", (progress, cancellationToken) => Scanner.ScanAsync(progress, cancellationToken));
    }

    private async Task RescanAsync()
    {
        await ClearUiForRescanAsync();

        await RunRootScanAsync("Rescanning", (progress, cancellationToken) => Scanner.RescanAsync(progress, cancellationToken));
    }

    private async Task RunRootScanAsync(string status, Func<IProgress<ScanProgress>, CancellationToken, Task<ScanSummary>> scanOperation)
    {
        _isScanning = true;
        _scanStatus = status;
        _scanMessage = null;
        _lastScan = null;
        _rootScanCancellation?.Dispose();
        _rootScanCancellation = new CancellationTokenSource();
        var cancellationToken = _rootScanCancellation.Token;
        _folderScanProgress = new ScanProgress(status, Options.Value.RootPath, 0, 0, 0);
        var progress = new Progress<ScanProgress>(value =>
        {
            _folderScanProgress = value;
            _ = InvokeAsync(async () =>
            {
                if (value.Phase == "Fast scan complete")
                {
                    await LoadAsync();
                    return;
                }

                StateHasChanged();
            });
        });

        try
        {
            _lastScan = await Task.Run(async () => await scanOperation(progress, cancellationToken), cancellationToken);
            await LoadAsync();
        }
        catch (OperationCanceledException)
        {
            _scanMessage = $"{status} cancelled.";
            await LoadAsync();
        }
        finally
        {
            _isScanning = false;
            _folderScanProgress = null;
            _rootScanCancellation?.Dispose();
            _rootScanCancellation = null;
        }
    }

    private void CancelRootScan()
    {
        _scanStatus = "Cancelling";
        _rootScanCancellation?.Cancel();
    }

    private async Task LoadAsync()
    {
        _snapshot = await Library.GetSnapshotAsync(_snapshot?.ActiveContainerId, _search, SelectedRating, _unratedOnly);
        PruneCollapsedSources();
        EnsureLabelArchiveSelected();
    }

    private async Task ToggleLabelAffeAsync()
    {
        if (_labelAffeMode)
        {
            await FlushLabelAffeAutosaveAsync();
        }

        _labelAffeMode = !_labelAffeMode;
        if (!_labelAffeMode)
        {
            await DisconnectLabelAffeKeyboardAsync();
            return;
        }

        _showArchivesOnly = true;
        if (_snapshot is null)
        {
            await LoadAsync();
        }

        _labelSuggestions = await Library.GetLabelSuggestionsAsync();
        SelectLabelArchive(SelectedContainer?.Kind == AssetKinds.Zip ? SelectedContainer : SelectedLabelArchive);
        await ConnectLabelAffeKeyboardAsync();
        await ScrollActiveLabelArchiveAsync();
    }

    private async Task SelectContainerAsync(long id)
    {
        await ClearLoadedImagesAsync(id);
        _snapshot = await Library.GetSnapshotAsync(id, _search, SelectedRating, _unratedOnly);
        if (SelectedContainer is { Kind: AssetKinds.Zip } container && ShouldScanArchive(container))
        {
            await ScanArchiveAsync(container);
        }
    }

    private async Task OpenArchiveFromPreviewAsync(AssetCard archive)
    {
        ExpandSourceAncestors(archive);
        await SelectContainerAsync(archive.Id);
    }

    private async Task ScanArchiveAsync(AssetCard container)
    {
        if (_isArchiveScanning)
        {
            return;
        }

        _isArchiveScanning = true;
        _lastArchivePreviewRefresh = DateTimeOffset.MinValue;
        _lastArchivePreviewImageCount = 0;
        _archiveScanCancellation?.Dispose();
        _archiveScanCancellation = new CancellationTokenSource();
        var cancellationToken = _archiveScanCancellation.Token;
        _archiveScanProgress = new ScanProgress("Starting archive scan", container.RelativePath, 0, 0, 0);
        var progress = new Progress<ScanProgress>(value =>
        {
            _archiveScanProgress = value;
            _ = InvokeAsync(async () =>
            {
                if (ShouldRefreshArchivePreview(value))
                {
                    await RefreshArchivePreviewAsync();
                    return;
                }

                StateHasChanged();
            });
        });

        try
        {
            await Task.Run(() => Scanner.ScanContainerAsync(container.Id, progress, cancellationToken), cancellationToken);
            _snapshot = await Library.GetSnapshotAsync(container.Id, _search, SelectedRating, _unratedOnly);
        }
        catch (OperationCanceledException)
        {
            _snapshot = await Library.GetSnapshotAsync(container.Id, _search, SelectedRating, _unratedOnly);
        }
        finally
        {
            _isArchiveScanning = false;
            _archiveScanProgress = null;
            _archiveScanCancellation?.Dispose();
            _archiveScanCancellation = null;
        }
    }

    private void CancelArchiveScan()
    {
        _archiveScanProgress = _archiveScanProgress is null
            ? null
            : _archiveScanProgress with { Phase = "Cancelling archive scan" };
        _archiveScanCancellation?.Cancel();
    }

    private async Task ClearUiForRescanAsync()
    {
        _archiveScanCancellation?.Cancel();

        if (_viewerAsset is not null)
        {
            await CloseViewer();
        }

        _editingAsset = null;
        _viewerAsset = null;
        _snapshot = null;
        _lastScan = null;
        _folderScanProgress = null;
        _archiveScanProgress = null;
        _isArchiveScanning = false;
        _lastArchivePreviewRefresh = DateTimeOffset.MinValue;
        _lastArchivePreviewImageCount = 0;
        _scanMessage = "Cleared current view. Starting rescan.";

        GC.Collect();
        GC.WaitForPendingFinalizers();
        GC.Collect();

        await InvokeAsync(StateHasChanged);
    }

    private bool ShouldRefreshArchivePreview(ScanProgress progress)
    {
        if (progress.Images <= _lastArchivePreviewImageCount)
        {
            return false;
        }

        var now = DateTimeOffset.UtcNow;
        if (progress.Images > 1 && now - _lastArchivePreviewRefresh < TimeSpan.FromMilliseconds(700))
        {
            return false;
        }

        _lastArchivePreviewImageCount = progress.Images;
        _lastArchivePreviewRefresh = now;
        return true;
    }

    private async Task RefreshArchivePreviewAsync()
    {
        if (_isRefreshingArchivePreview)
        {
            return;
        }

        _isRefreshingArchivePreview = true;
        try
        {
            await LoadAsync();
        }
        finally
        {
            _isRefreshingArchivePreview = false;
        }
    }

    private async Task OpenViewer(AssetCard asset)
    {
        _viewerAsset = asset;
        await ConnectViewerKeyboardAsync();
    }

    private async Task CloseViewer()
    {
        _viewerAsset = null;
        await DisconnectViewerKeyboardAsync();
    }

    private async Task PreviousImage()
    {
        MoveViewer(-1);
        await ScrollActiveFilmstripItemAsync();
    }

    private async Task NextImage()
    {
        MoveViewer(1);
        await ScrollActiveFilmstripItemAsync();
    }

    [JSInvokable]
    public async Task PreviousImageFromKeyboard()
    {
        await PreviousImage();
        StateHasChanged();
    }

    [JSInvokable]
    public async Task NextImageFromKeyboard()
    {
        await NextImage();
        StateHasChanged();
    }

    [JSInvokable]
    public async Task CloseViewerFromKeyboard()
    {
        await CloseViewer();
    }

    private void MoveViewer(int direction)
    {
        if (_viewerAsset is null)
        {
            return;
        }

        var images = CurrentImages();
        var index = images.FindIndex(image => image.Id == _viewerAsset.Id);
        if (index < 0 || images.Count == 0)
        {
            return;
        }

        var nextIndex = (index + direction + images.Count) % images.Count;
        _viewerAsset = images[nextIndex];
    }

    private async Task ShowViewerImageAsync(AssetCard asset)
    {
        _viewerAsset = asset;
        await ScrollActiveFilmstripItemAsync();
    }

