    private static RenderFragment ViewerMedia(AssetCard asset) => builder =>
    {
        if (asset.IsVideo)
        {
            builder.OpenElement(0, "video");
            builder.AddAttribute(1, "src", ImageUrl(asset.Id));
            builder.AddAttribute(2, "controls", true);
            builder.AddAttribute(3, "preload", "metadata");
            builder.AddAttribute(4, "autoplay", true);
            builder.AddAttribute(5, "loop", true);
            builder.CloseElement();
            return;
        }

        if (asset.IsAudio)
        {
            builder.OpenElement(5, "div");
            builder.AddAttribute(6, "class", "audio-viewer");
            builder.OpenElement(7, "span");
            builder.AddAttribute(8, "class", "media-kind");
            builder.AddContent(9, "AUD");
            builder.CloseElement();
            builder.OpenElement(10, "audio");
            builder.AddAttribute(11, "src", ImageUrl(asset.Id));
            builder.AddAttribute(12, "controls", true);
            builder.AddAttribute(13, "preload", "metadata");
            builder.AddAttribute(14, "autoplay", true);
            builder.CloseElement();
            builder.CloseElement();
            return;
        }

        builder.OpenElement(15, "img");
        builder.AddAttribute(16, "src", ImageUrl(asset.Id));
        builder.AddAttribute(17, "alt", asset.DisplayName);
        builder.CloseElement();
    };

    private static RenderFragment FilmstripMedia(AssetCard asset) => builder =>
    {
        if (asset.IsImage)
        {
            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "src", ImageUrl(asset.Id));
            builder.AddAttribute(2, "alt", asset.DisplayName);
            builder.CloseElement();
            return;
        }

        if (asset.IsVideo)
        {
            builder.OpenElement(3, "video");
            builder.AddAttribute(4, "src", $"{ImageUrl(asset.Id)}#t=0.1");
            builder.AddAttribute(5, "preload", "metadata");
            builder.AddAttribute(6, "muted", true);
            builder.AddAttribute(7, "playsinline", true);
            builder.CloseElement();
            return;
        }

        builder.OpenElement(8, "span");
        builder.AddAttribute(9, "class", "media-placeholder compact");
        builder.OpenElement(10, "span");
        builder.AddAttribute(11, "class", "media-kind");
        builder.AddContent(12, "AUD");
        builder.CloseElement();
        builder.CloseElement();
    };

    private static string SourceIndent(AssetCard asset, bool flatten = false)
    {
        var level = flatten ? 0 : Math.Min(asset.Depth, 6);
        var nested = Math.Min(level, 4);
        var thumbSize = Math.Max(34, 58 - (nested * 5));
        var rowHeight = Math.Max(46, 76 - (nested * 7));
        var rowGap = Math.Max(4, 8 - nested);
        var padY = Math.Max(4, 8 - nested);
        var gap = Math.Max(7, 12 - nested);
        var fontSize = Math.Max(0.84, 1 - (nested * 0.035));
        var smallSize = Math.Max(0.64, 0.78 - (nested * 0.025));

        return string.Join("; ", [
            $"--source-level: {level}",
            $"--source-thumb-size: {thumbSize}px",
            $"--source-row-height: {rowHeight}px",
            $"--source-row-gap: {rowGap}px",
            $"--source-pad-y: {padY}px",
            $"--source-gap: {gap}px",
            $"--source-font-size: {fontSize:0.###}rem",
            $"--source-small-size: {smallSize:0.###}rem"
        ]);
    }

    private static string SourceStatus(AssetCard asset)
    {
        if (asset.IsIgnored)
        {
            return "Ignored";
        }

        if (asset.SourceType == AssetSourceTypes.ZipArchivePreview)
        {
            return asset.ImageCount > 0 ? "Media found, click to scan" : "Click to scan archive";
        }

        if (asset.Kind == AssetKinds.Zip && asset.ChildCount == 0)
        {
            return "Click to scan archive";
        }

        return $"{asset.ImageCount} media files";
    }

    private static bool ShouldScanArchive(AssetCard asset)
    {
        return !asset.IsIgnored && (asset.SourceType == AssetSourceTypes.ZipArchivePreview || asset.ChildCount == 0);
    }

    private static string ProgressBarClass(ScanProgress progress)
    {
        return progress.WorkTotal > 0 ? "progress-bar determinate" : "progress-bar";
    }

    private static string ProgressBarStyle(ScanProgress progress)
    {
        if (progress.WorkTotal is not > 0)
        {
            return string.Empty;
        }

        var done = Math.Clamp(progress.WorkDone ?? 0, 0, progress.WorkTotal.Value);
        var percent = done * 100d / progress.WorkTotal.Value;
        return $"--progress-value: {percent:0.##}%";
    }

    private static string ProgressWorkText(ScanProgress progress)
    {
        if (progress.WorkTotal is not > 0)
        {
            return string.Empty;
        }

        var done = Math.Clamp(progress.WorkDone.GetValueOrDefault(), 0, progress.WorkTotal.Value);
        var percent = done * 100d / progress.WorkTotal.Value;
        return $"{done} of {progress.WorkTotal.Value} {progress.WorkLabel ?? "items"} done ({percent:0.#}%)";
    }

