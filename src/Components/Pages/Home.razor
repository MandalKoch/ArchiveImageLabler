    private IEnumerable<AssetCard> VisibleContainers()
    {
        if (_snapshot is null)
        {
            return [];
        }

        var byId = _snapshot.Containers.ToDictionary(container => container.Id);
        if (_showArchivesOnly)
        {
            return _snapshot.Containers.Where(container => container.Kind == AssetKinds.Zip);
        }

        return _snapshot.Containers.Where(container => IsSourceVisible(container, byId));
    }

    private bool IsSourceVisible(AssetCard container, Dictionary<long, AssetCard> byId)
    {
        var parentId = container.ParentId;
        while (parentId is not null && byId.TryGetValue(parentId.Value, out var parent))
        {
            if (_collapsedSourceIds.Contains(parent.Id))
            {
                return false;
            }

            parentId = parent.ParentId;
        }

        return true;
    }

    private bool HasSourceChildren(AssetCard asset)
    {
        return _snapshot?.Containers.Any(container => container.ParentId == asset.Id) == true;
    }

    private bool IsSourceCollapsed(long id) => _collapsedSourceIds.Contains(id);

    private void ToggleSourceCollapsed(long id)
    {
        if (_collapsedSourceIds.Contains(id))
        {
            _collapsedSourceIds.Remove(id);
        }
        else
        {
            _collapsedSourceIds.Add(id);
        }
    }

    private void PruneCollapsedSources()
    {
        if (_snapshot is null)
        {
            _collapsedSourceIds.Clear();
            return;
        }

        var availableIds = _snapshot.Containers.Select(container => container.Id).ToHashSet();
        _collapsedSourceIds.RemoveWhere(id => !availableIds.Contains(id));
    }

    private void ExpandSourceAncestors(AssetCard asset)
    {
        if (_snapshot is null)
        {
            return;
        }

        var byId = _snapshot.Containers.ToDictionary(container => container.Id);
        var parentId = asset.ParentId;
        while (parentId is not null && byId.TryGetValue(parentId.Value, out var parent))
        {
            _collapsedSourceIds.Remove(parent.Id);
            parentId = parent.ParentId;
        }
    }

