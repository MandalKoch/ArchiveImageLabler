    private void SelectLabelArchive(AssetCard? archive)
    {
        if (archive is null)
        {
            _labelArchiveId = null;
            _labelName = string.Empty;
            _labelDescription = string.Empty;
            _labelTags.Clear();
            _labelRating = null;
            return;
        }

        _labelArchiveId = archive.Id;
        _labelName = archive.LabelName;
        _labelDescription = archive.Description;
        _labelTags.Clear();
        _labelTags.AddRange(ParseTags(archive.Tags));
        _labelTagInput = string.Empty;
        _labelRating = archive.Rating;
        _labelAffeDirty = false;
    }

    private async Task SelectLabelArchiveAsync(AssetCard? archive)
    {
