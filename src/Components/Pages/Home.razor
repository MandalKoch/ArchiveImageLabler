    private async Task SaveLabelAffeAsync()
    {
        CancelLabelAffeAutosave();
        AddLabelTagFromInput();
        await SaveLabelAffeDraftAsync(force: true);
    }

    private async Task SaveLabelAffeDraftAsync(bool force = false, CancellationToken cancellationToken = default)
    {
        if (SelectedLabelArchive is not { } archive || (!force && !_labelAffeDirty))
        {
            return;
        }

        var archiveId = archive.Id;
        var labelName = _labelName;
        var description = _labelDescription;
        var tags = string.Join(", ", _labelTags);
        var rating = _labelRating;

        await Library.SaveMetadataAsync(archiveId, labelName, description, tags, rating, cancellationToken);
        _labelSuggestions = await Library.GetLabelSuggestionsAsync(cancellationToken);
        UpdateAssetMetadata(archiveId, labelName, description, tags, rating);
        if (_labelArchiveId == archiveId)
        {
            _labelAffeDirty = false;
        }
    }

    private async Task SaveAndNextLabelAffeAsync()
    {
        if (SelectedLabelArchive is not { } archive)
        {
            return;
        }

        var archives = LabelArchives().ToList();
        var index = archives.FindIndex(item => item.Id == archive.Id);
        await SaveLabelAffeAsync();

        archives = LabelArchives().ToList();
        if (archives.Count == 0)
        {
            return;
        }

        var nextIndex = index < 0 ? 0 : Math.Min(index + 1, archives.Count - 1);
        SelectLabelArchive(archives[nextIndex]);
    }

    private async Task FlushLabelAffeAutosaveAsync()
    {
        CancelLabelAffeAutosave();
        await SaveLabelAffeDraftAsync();
    }

    private void QueueLabelAffeAutosave()
    {
        if (SelectedLabelArchive is null)
        {
            return;
        }

        _labelAffeDirty = true;
        CancelLabelAffeAutosave();
        var cancellation = new CancellationTokenSource();
        _labelAutosaveCancellation = cancellation;
        _ = RunLabelAffeAutosaveAsync(cancellation);
    }

    private async Task RunLabelAffeAutosaveAsync(CancellationTokenSource cancellation)
    {
        try
        {
            await Task.Delay(650, cancellation.Token);
            await InvokeAsync(async () =>
            {
                if (_labelAutosaveCancellation == cancellation)
                {
                    _labelAutosaveCancellation = null;
                }

                await SaveLabelAffeDraftAsync(cancellationToken: cancellation.Token);
                StateHasChanged();
            });
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            cancellation.Dispose();
        }
    }

    private void CancelLabelAffeAutosave()
    {
        _labelAutosaveCancellation?.Cancel();
        _labelAutosaveCancellation = null;
    }

    private void HandleLabelNameInput(ChangeEventArgs args)
    {
        _labelName = args.Value?.ToString() ?? string.Empty;
        QueueLabelAffeAutosave();
    }

    private void HandleLabelDescriptionInput(ChangeEventArgs args)
    {
        _labelDescription = args.Value?.ToString() ?? string.Empty;
        QueueLabelAffeAutosave();
    }

    private async Task HandleLabelRatingChanged(ChangeEventArgs args)
    {
        _labelRating = int.TryParse(args.Value?.ToString(), out var rating) ? rating : null;
        _labelAffeDirty = true;
        CancelLabelAffeAutosave();
        await SaveLabelAffeDraftAsync();
    }

    private bool AddLabelTagFromInput()
    {
        var changed = false;
        foreach (var tag in ParseTags(_labelTagInput))
        {
            changed |= AddLabelTag(tag);
        }

        _labelTagInput = string.Empty;
        return changed;
    }

    private async Task AddLabelTagFromInputAsync()
    {
        if (!AddLabelTagFromInput())
        {
            return;
        }

        _labelAffeDirty = true;
        CancelLabelAffeAutosave();
        await SaveLabelAffeDraftAsync();
    }

    private bool AddLabelTag(string tag)
    {
        tag = NormalizeTag(tag);
        if (string.IsNullOrWhiteSpace(tag) || _labelTags.Contains(tag, StringComparer.OrdinalIgnoreCase))
        {
            return false;
        }

        _labelTags.Add(tag);
        return true;
    }

    private async Task AddLabelTagAsync(string tag)
    {
        if (!AddLabelTag(tag))
        {
            return;
        }

        _labelAffeDirty = true;
        CancelLabelAffeAutosave();
        await SaveLabelAffeDraftAsync();
    }

    private async Task RemoveLabelTagAsync(string tag)
    {
        if (_labelTags.RemoveAll(item => string.Equals(item, tag, StringComparison.OrdinalIgnoreCase)) == 0)
        {
            return;
        }

        _labelAffeDirty = true;
        CancelLabelAffeAutosave();
        await SaveLabelAffeDraftAsync();
    }

    private async Task HandleLabelTagKeyUp(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or "," or ";")
        {
            await AddLabelTagFromInputAsync();
        }
    }

    private IEnumerable<string> TagSuggestions(AssetCard archive)
    {
        var query = _labelTagInput.Trim();
        return FileNameSuggestionParts(archive.Name)
            .Concat(_labelSuggestions.Tags.OrderBy(tag => tag))
            .Select(NormalizeTag)
            .Where(tag => !string.IsNullOrWhiteSpace(tag))
            .Where(tag => string.IsNullOrWhiteSpace(query) || tag.Contains(query, StringComparison.OrdinalIgnoreCase))
            .Where(tag => !_labelTags.Contains(tag, StringComparer.OrdinalIgnoreCase))
            .Distinct(StringComparer.OrdinalIgnoreCase);
    }

    private IEnumerable<string> NameSuggestions(AssetCard archive)
    {
        return FileNameSuggestions(archive.Name)
            .Concat(_labelSuggestions.Names.OrderBy(name => name))
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct(StringComparer.OrdinalIgnoreCase);
    }

    private IEnumerable<string> TextSuggestions(AssetCard archive)
    {
        return (string.IsNullOrWhiteSpace(_labelName)
                ? FileNameSuggestions(archive.Name)
                : new[] { _labelName }.Concat(FileNameSuggestionParts(archive.Name)))
            .Concat(_labelSuggestions.Text)
            .Where(text => !string.IsNullOrWhiteSpace(text))
            .Distinct(StringComparer.OrdinalIgnoreCase);
    }

    private async Task ApplyNameSuggestionAsync(string suggestion)
    {
        _labelName = suggestion;
        _labelAffeDirty = true;
        CancelLabelAffeAutosave();
        await SaveLabelAffeDraftAsync();
    }

    private async Task ApplyTextSuggestionAsync(string suggestion)
    {
        _labelDescription = string.IsNullOrWhiteSpace(_labelDescription)
            ? suggestion
            : $"{_labelDescription.Trim()}\n{suggestion}";
        _labelAffeDirty = true;
        CancelLabelAffeAutosave();
        await SaveLabelAffeDraftAsync();
    }

    private static IEnumerable<string> ParseTags(string tags)
    {
        return tags.Split([',', ';', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(NormalizeTag)
            .Where(tag => !string.IsNullOrWhiteSpace(tag))
            .Distinct(StringComparer.OrdinalIgnoreCase);
    }

    private static IEnumerable<string> FileNameSuggestions(string fileName)
    {
        return new[] { CleanArchiveName(fileName) }
            .Concat(FileNameSuggestionParts(fileName))
            .Where(value => !string.IsNullOrWhiteSpace(value));
    }

    private static IEnumerable<string> FileNameSuggestionParts(string fileName)
    {
        return System.IO.Path.GetFileNameWithoutExtension(fileName)
            .Split('-', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(CleanSuggestionPart)
            .Where(part => part.Length > 2 && !part.All(char.IsDigit));
    }

    private static string CleanSuggestionPart(string value)
    {
        return value
            .Replace('_', ' ')
            .Trim();
    }

    private static string NormalizeTag(string tag)
    {
        return tag.Trim().ToLowerInvariant();
    }

    private static string CleanArchiveName(string value)
    {
        return System.IO.Path.GetFileNameWithoutExtension(value)
            .Replace('_', ' ')
            .Replace('-', ' ')
            .Trim();
    }

