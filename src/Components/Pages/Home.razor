        SelectLabelArchive(archive);
        await ScrollActiveLabelArchiveAsync();
    }

    private async Task MoveLabelArchiveAsync(int direction)
    {
        var archives = LabelArchives().ToList();
        if (archives.Count == 0)
        {
            return;
        }

        var index = _labelArchiveId is null
            ? -1
            : archives.FindIndex(archive => archive.Id == _labelArchiveId.Value);
        var nextIndex = index < 0
            ? 0
            : (index + direction + archives.Count) % archives.Count;

        await FlushLabelAffeAutosaveAsync();
        SelectLabelArchive(archives[nextIndex]);
        await ScrollActiveLabelArchiveAsync();
        StateHasChanged();
    }

